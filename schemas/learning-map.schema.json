{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fahem.ai/schemas/learning-map.schema.json",
  "title": "LearningMapCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "documentTitle",
    "units"
  ],
  "properties": {
    "documentTitle": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "units": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "$ref": "#/$defs/unit"
      }
    }
  },
  "$defs": {
    "sourceRange": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "startPage",
        "endPage",
        "evidenceIds"
      ],
      "properties": {
        "startPage": {
          "type": "integer",
          "minimum": 1
        },
        "endPage": {
          "type": "integer",
          "minimum": 1
        },
        "evidenceIds": {
          "type": "array",
          "minItems": 1,
          "maxItems": 20,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "concept": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "description",
        "source"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        }
      }
    },
    "lesson": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "source",
        "concepts"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        },
        "concepts": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/concept"
          }
        }
      }
    },
    "unit": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "summary",
        "source",
        "lessons"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "$ref": "#/$defs/sourceRange"
        },
        "lessons": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/lesson"
          }
        }
      }
    }
  }
}
