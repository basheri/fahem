{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fahem.ai/schemas/quiz.schema.json",
  "title": "GroundedQuizCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "questions"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "choices",
          "correctChoiceIndex",
          "explanation",
          "evidenceIds"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "choices": {
            "type": "array",
            "minItems": 3,
            "maxItems": 5,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "correctChoiceIndex": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          },
          "explanation": {
            "type": "string",
            "minLength": 1
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
