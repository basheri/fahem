# Copy to .env for local development. Never commit .env.

APP_ENV=development
APP_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000

# Anonymous session policy
SESSION_SIGNING_SECRET=replace-with-at-least-32-random-bytes
SESSION_IDLE_TTL_SECONDS=7200
SESSION_ABSOLUTE_TTL_SECONDS=86400
SESSION_COOKIE_SECURE=false

# Upload limits
MAX_PDF_BYTES=52428800
MAX_PDF_PAGES=300
MAX_QUESTION_CHARS=2000
MAX_ACTIVE_JOBS_PER_SESSION=1

# PostgreSQL / pgvector
POSTGRES_DB=fahem
POSTGRES_USER=fahem
POSTGRES_PASSWORD=replace-local-password
DATABASE_URL=postgresql+psycopg://fahem:replace-local-password@postgres:5432/fahem

# Redis
REDIS_URL=redis://redis:6379/0

# S3-compatible object storage
S3_ENDPOINT_URL=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=fahem-session-data
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=replace-local-secret
S3_FORCE_PATH_STYLE=true

# OpenRouter: server-side only
OPENROUTER_API_KEY=replace-with-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Fahem AI
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_REQUIRE_ZDR=true
OPENROUTER_DATA_COLLECTION=deny
OPENROUTER_REQUEST_TIMEOUT_SECONDS=60
OPENROUTER_MAX_RETRIES=2
OPENROUTER_MAX_INPUT_TOKENS=24000
OPENROUTER_MAX_OUTPUT_TOKENS=3000
OPENROUTER_MAX_COST_USD_PER_REQUEST=0.10

# Model IDs are examples only. Set valid OpenRouter model IDs during deployment.
OPENROUTER_ANALYSIS_MODEL=replace-with-analysis-model-id
OPENROUTER_ANALYSIS_FALLBACK_MODEL=replace-with-analysis-fallback-model-id
OPENROUTER_CHAT_MODEL=replace-with-chat-model-id
OPENROUTER_CHAT_FALLBACK_MODEL=replace-with-chat-fallback-model-id
OPENROUTER_VISION_MODEL=replace-with-vision-model-id
OPENROUTER_VISION_FALLBACK_MODEL=replace-with-vision-fallback-model-id
OPENROUTER_GENERATION_MODEL=replace-with-generation-model-id
OPENROUTER_GENERATION_FALLBACK_MODEL=replace-with-generation-fallback-model-id

# Embeddings: local is preferred for privacy in the MVP
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=intfloat/multilingual-e5-base
EMBEDDING_DIMENSION=768

# OCR
TESSERACT_LANGUAGES=ara+eng
OCR_TEXT_DENSITY_THRESHOLD=0.15
OCR_MIN_EXTRACTED_CHARS_PER_PAGE=40

# Observability: do not log content
LOG_LEVEL=INFO
LOG_CONTENT=false
OTEL_EXPORTER_OTLP_ENDPOINT=
SENTRY_DSN=

# Optional production malware scanning
CLAMAV_ENABLED=false
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
