{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fahem.ai/schemas/answer.schema.json",
  "title": "GroundedAnswerCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "answer",
    "claims",
    "unsupportedPart",
    "limitations"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "answered",
        "partially_answered",
        "not_found"
      ]
    },
    "answer": {
      "type": "string",
      "minLength": 1,
      "maxLength": 12000
    },
    "claims": {
      "type": "array",
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "evidenceIds"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[A-Za-z0-9_-]{6,100}$"
            }
          }
        }
      }
    },
    "unsupportedPart": {
      "type": [
        "string",
        "null"
      ],
      "maxLength": 3000
    },
    "limitations": {
      "type": "array",
      "maxItems": 10,
      "items": {
        "type": "string",
        "maxLength": 1000
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "not_found"
          }
        }
      },
      "then": {
        "properties": {
          "claims": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "partially_answered"
          }
        }
      },
      "then": {
        "properties": {
          "unsupportedPart": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  ]
}
