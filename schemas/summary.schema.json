{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fahem.ai/schemas/summary.schema.json",
  "title": "GroundedSummaryCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "summary",
    "keyPoints"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 20000
    },
    "keyPoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 30,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "text",
          "evidenceIds"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 10,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
