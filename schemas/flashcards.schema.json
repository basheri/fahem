{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fahem.ai/schemas/flashcards.schema.json",
  "title": "GroundedFlashcardsCandidate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "cards"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 300
    },
    "cards": {
      "type": "array",
      "minItems": 1,
      "maxItems": 100,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "front",
          "back",
          "evidenceIds"
        ],
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "question_answer",
              "term_definition",
              "concept_example"
            ]
          },
          "front": {
            "type": "string",
            "minLength": 1
          },
          "back": {
            "type": "string",
            "minLength": 1
          },
          "evidenceIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 8,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
